					</settings>
					<enemy>
						<pet id="991" level="105">
							<status>
								<hp>240000</hp>
							</status>
							<initBuff>-8,17,20,3608,3609,61</initBuff>
							<loopSkill>14303,14304,14305,10498</loopSkill>
						</pet>
					</enemy>
					<winHandler>
						<button type="choose">
							<action>openHintbox</action>
							<param>type=PetSelect</param>
						    <param>title=选择要进化的目灵兽</param>
						    <param>option_num=2</param>
							<param>callback=evolve</param>
