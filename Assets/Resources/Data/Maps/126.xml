			<battle>
				<branch id="default">
					<settings count="6">
						<weather>1</weather>
					</settings>
					<enemy>
						<pet id="981" level="105">
							<status>
								<hp>30000</hp>
							</status>
							<initBuff>14,17,20,-3008</initBuff>
							<loopSkill>10493,10490,10495,10491,10500</loopSkill>
							<superSkill>10498</superSkill>
						</pet>
					</enemy>
					<winHandler>
						<button type="auto">
							<action>getPet</action>
							<param>981,100</param>
							<condition>activity[soul].done[north][1]=[bool]false[default]false</condition>
						</button>
						<button type="auto">
							<action>openHintbox</action>
							<param>type=Item</param>
							<param>title=提示</param>
							<param>content=【目灵兽】已经放入精灵仓库</param>
							<param>item_icon=pet[981]</param>
							<param>option_num=1</param>
							<condition>activity[soul].done[north][1]=[bool]false[default]false</condition>
						</button>
						<button type="auto">
							<action>setActivity</action>
							<param>soul</param>
							<param>done[north][1]=true</param>
							<condition>activity[soul].done[north][1]=[bool]false[default]false</condition>
						</button>
						<button type="auto">
							<action>setItem</action>
							<param>add</param>
							<param>23004,1</param>
							<condition>random[old]&lt;10</condition>
						</button>
						<button type="auto">
							<action>openHintbox</action>
							<param>type=Item</param>
							<param>title=提示</param>
							<param>content=1个草目璞玉已经放入背包</param>
							<param>item_icon=buff[430004]</param>
							<param>option_num=1</param>
							<condition>random[old]&lt;10</condition>
						</button>
					</winHandler>
				</branch>
				<branch id="evolve">
					<settings count="6">
						<weather>1</weather>
						<initBuff>(field:600001)</initBuff>
						<limit>(elementNOT3)(elementNOT12)</limit>
