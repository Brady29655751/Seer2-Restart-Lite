			</battle>
			<eventHandler>
				<button type="click">
					<action>openDialog</action>
					<param>default</param>
				</button>
			</eventHandler>
			<callbackHandler>
				<button type="choose">
					<action>openHintbox</action>
					<param>type=PetSelect</param>
				    <param>title=选择要进化的目灵兽</param>
				    <param>option_num=2</param>
					<param>callback=evolve</param>
				    <condition>data.PetSelect.uidNOT981|data.PetSelect.level&lt;100</condition>
				</button>
				<button type="evolve">
				    <action>openHintbox</action>
				    <param>type=Item</param>
				    <param>title=提示</param>
				    <param>content=必须选择等级100的目灵兽！</param>
				    <param>item_icon=pet[981]</param>
				    <param>option_num=1</param>
					<param>callback=choose</param>
				    <condition>data.PetSelect.uidNOT981|data.PetSelect.level&lt;100</condition>
				</button>
				<button type="evolve">
				    <action>openHintbox</action>
				    <param>type=Item</param>
				    <param>title=提示</param>
				    <param>content=目灵兽已成功超进化</param>
				    <param>item_icon=pet[991]</param>
				    <param>option_num=1</param>
				    <condition>data.PetSelect.uid=981</condition>
				    <condition>data.PetSelect.levelGTE100</condition>
				</button>
				<button type="evolve">
				    <action>evolvePet</action>
				    <param>index=data.PetSelectIndex</param>
				    <param>991</param>
				    <condition>data.PetSelect.uid=981</condition>
				    <condition>data.PetSelect.levelGTE100</condition>
				</button>
			</callbackHandler>
		</npc>
		<teleport id="1" name="权力之帐" pos="85,140" targetMapId="110"/>
	</entities>
</map>